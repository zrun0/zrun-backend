# Environment Configuration
ENV=dev

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zrun
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
REDIS_DB=0

# Authentication
JWKS_URL=http://localhost:8080/.well-known/jwks.json
JWT_AUDIENCE=zrun
JWT_ISSUER=https://casdoor.example.com

# Server
PORT=50051
MAX_WORKERS=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
ENABLE_AUTH=true
ENABLE_METRICS=true
ENABLE_TRACING=false
