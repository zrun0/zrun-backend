# =============================================================================
# Docker Ignore File
# =============================================================================
# Excludes files not needed in Docker builds to reduce context size
# and prevent issues with platform-specific artifacts.
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Git
.git/
.gitignore

# Docker
docker/
Dockerfile*
.dockerignore

# Documentation
*.md
docs/

# Tests (not needed in production image)
tests/
test_*.py
*_test.py
conftest.py
.pytest_cache/
.coverage
htmlcov/

# Config files
.env
.env.*
*.local

# Build artifacts
*.log
*.tmp

# OS
.DS_Store
Thumbs.db
