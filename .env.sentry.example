# =============================================================================
# Sentry Configuration Template
# =============================================================================
#
# Copy this section to your .env file and update with your actual values.
# Get your DSN from: https://sentry.io -> Settings -> Projects -> Client Keys (DSN)
#
# Documentation: https://docs.sentry.io/platforms/python/

# =============================================================================
# Required
# =============================================================================
# The Sentry Data Source Name (DSN) - uniquely identifies your Sentry project
# Example: https://examplePublicKey@o0.ingest.sentry.io/123456
SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/project-id

# =============================================================================
# Optional - Environment
# =============================================================================
# Environment name for grouping errors in Sentry
# Common values: development, staging, production
# Default: development
SENTRY_ENVIRONMENT=development

# =============================================================================
# Optional - Performance Monitoring
# =============================================================================
# Fraction of transactions to sample for performance monitoring (0.0 to 1.0)
# - 0.0 = No performance monitoring
# - 1.0 = 100% sampling (high volume, not recommended for production)
# - 0.1 = 10% sampling (recommended starting point)
# Default: 0.1
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# Optional - Release Tracking
# =============================================================================
# Release version for tracking errors by deployment
# Examples: v1.0.0, v0.1.0-dev, main-abc123
# Leave empty to disable release tracking
SENTRY_RELEASE=v0.1.0-dev
